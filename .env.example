# ─────────────────────────────────────────────────────────────────────────────
#  Curbsite Sales Agent — Environment Variables
#  Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Recommended: Gmail with a dedicated sending address + App Password
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sending-address@gmail.com
SMTP_PASS=your-app-password
FROM_NAME=Steele @ Curbsite
FROM_EMAIL=your-sending-address@gmail.com
REPLY_TO=steele.stout@gmail.com

# ── Calendly ─────────────────────────────────────────────────────────────────
# Create a "15-minute intro call" event type on Calendly, copy the direct link.
# e.g. https://calendly.com/steele-curbsite/15min
CALENDLY_URL=https://calendly.com/your-link-here/15min
# Optional: webhook secret for booking confirmation callbacks
CALENDLY_WEBHOOK_SECRET=

# ── Agency identity ───────────────────────────────────────────────────────────
AGENCY_NAME=Curbsite.co
AGENCY_URL=https://curbsite.co
AGENCY_OWNER=Steele Stout

# ── Pricing (used in email copy and dossiers) ─────────────────────────────────
PRICE_ENTRY=800
PRICE_MID=1400
PRICE_TOP=2200
PRICE_CARE_MIN=75
PRICE_CARE_MAX=125

# ── Lead sourcing ─────────────────────────────────────────────────────────────
# Optional: Yelp Fusion API key (free tier = 500 calls/day)
# Without this, falls back to lightweight Google Maps scrape
YELP_API_KEY=

# Target cities and niches (comma-separated)
TARGET_CITIES=Kokomo,Indianapolis,Fort Wayne
TARGET_NICHES=restaurant,photography,salon,contractor,fitness,dental

# ── Lead scoring thresholds ───────────────────────────────────────────────────
SCORE_MIN_EMAIL=40       # Minimum score to attempt email outreach

# ── Sending limits (safety rails) ────────────────────────────────────────────
MAX_EMAILS_PER_DAY=25
MAX_FOLLOWUPS_PER_WEEK=50

# ── Delays between API calls (seconds) ───────────────────────────────────────
PROSPECTING_DELAY=2
OUTREACH_DELAY=5

# ── Paths ─────────────────────────────────────────────────────────────────────
DB_PATH=data/leads/leads.db
CACHE_DIR=data/cache

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Mockup hosting (Netlify free tier) ───────────────────────────────────────
# https://app.netlify.com/user/applications → Personal access tokens
NETLIFY_ACCESS_TOKEN=

# ── Domain registration (Namecheap) ──────────────────────────────────────────
# https://www.namecheap.com/support/api/intro/
# Your Namecheap account username (not email)
NAMECHEAP_USERNAME=
NAMECHEAP_API_KEY=
# Your public IP (the machine running this script) — required by Namecheap API
# Find it: curl ifconfig.me
NAMECHEAP_CLIENT_IP=
# Set to 1 to use sandbox (no real purchases) — USE THIS FOR TESTING
NAMECHEAP_SANDBOX=1

# Registrant info for domain purchases (used in Namecheap WHOIS)
REGISTRANT_FIRST_NAME=Steele
REGISTRANT_LAST_NAME=Stout
REGISTRANT_ADDRESS=123 Main St
REGISTRANT_CITY=Kokomo
REGISTRANT_STATE=IN
REGISTRANT_ZIP=46902
REGISTRANT_COUNTRY=US
REGISTRANT_PHONE=+1.5555555555
REGISTRANT_EMAIL=steele.stout@gmail.com

# ── VPS deployment (Hostinger — shared infra for curbsite.co itself) ────────
# Your Hostinger VPS IP is 187.77.5.53 (see deploy.ps1)
HOSTINGER_VPS_HOST=187.77.5.53
HOSTINGER_VPS_USER=root
# IMPORTANT: pk.ppk is PuTTY format. paramiko needs OpenSSH.
# Convert with: puttygen pk.ppk -O private-openssh -o ~/.ssh/curbsite_rsa
# Then: chmod 600 ~/.ssh/curbsite_rsa
HOSTINGER_VPS_KEY_PATH=~/.ssh/curbsite_rsa
HOSTINGER_VPS_IP=187.77.5.53
VPS_DEPLOY_ROOT=/var/www

# ── Client VPS provisioning (Hetzner — Track A, one VPS per client) ─────────
# https://console.hetzner.cloud → Security → API Tokens → Generate token
HETZNER_API_TOKEN=
# Datacenter: ash (Ashburn VA), nbg1 (Nuremberg DE), fsn1 (Falkenstein DE)
HETZNER_DATACENTER=ash
# Name of the SSH key you uploaded to Hetzner project → Security → SSH Keys
HETZNER_SSH_KEY_NAME=curbsite

# ── Reply monitoring (IMAP) ───────────────────────────────────────────────────
# For Gmail: enable IMAP in Settings → Forwarding and POP/IMAP
# Use the same credentials as SMTP_USER / SMTP_PASS
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── Owner portal ──────────────────────────────────────────────────────────────
# The URL of the CurbSite client portal (where clients upload files, pay, etc.)
CURBSITE_PORTAL_URL=https://curbsite.co/portal
# Local path where portal file uploads are synced (used by site_builder.py)
# TODO: Steele to clarify — this could be an rsync from the VPS, a Google Drive
# mount, or a direct path if the builder runs on the same VPS as the portal.
PORTAL_FILE_BASE_PATH=data/portal_uploads

# ── OpenClaw / Rook voice agent ──────────────────────────────────────────────
# Rook is NOT yet deployed. Set these once you create the OpenClaw account.
# See docs/ROOK_SETUP.md for full setup instructions.
# IMPORTANT: Rook may only make WARM calls (FCC compliance). See ROOK_SETUP.md.
OPENCLAW_API_KEY=
OPENCLAW_AGENT_ID=
OPENCLAW_API_BASE=https://api.openclaw.ai/v1

# ── Founding clients ──────────────────────────────────────────────────────────
# How many free founding-client spots are left (update as spots fill)
FOUNDING_CLIENTS_REMAINING=5

# ── Curbsite portal auth (for portal_sync.py) ─────────────────────────────────
# The email + password you use to log in at curbsite.co/crm/login
# NEVER commit these to git — they live in .env only
CURBSITE_OWNER_EMAIL=steele.stout@gmail.com
CURBSITE_OWNER_PASSWORD=
# Optional: API key for direct /api/projects access (cleaner than session cookies)
CURBSITE_CRM_API_KEY=
