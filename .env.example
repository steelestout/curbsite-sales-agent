# ─────────────────────────────────────────────────────────────────────────────
#  Curbsite Sales Agent — Environment Variables
#  Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Recommended: Gmail with a dedicated sending address + App Password
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sending-address@gmail.com
SMTP_PASS=your-app-password
FROM_NAME=Steele @ Curbsite
FROM_EMAIL=your-sending-address@gmail.com
REPLY_TO=steele.stout@gmail.com

# ── Calendly ─────────────────────────────────────────────────────────────────
# Create a "15-minute intro call" event type on Calendly, copy the direct link.
# e.g. https://calendly.com/steele-curbsite/15min
CALENDLY_URL=https://calendly.com/your-link-here/15min
# Optional: webhook secret for booking confirmation callbacks
CALENDLY_WEBHOOK_SECRET=

# ── Agency identity ───────────────────────────────────────────────────────────
AGENCY_NAME=Curbsite.co
AGENCY_URL=https://curbsite.co
AGENCY_OWNER=Steele Stout

# ── Pricing (used in email copy and dossiers) ─────────────────────────────────
PRICE_ENTRY=800
PRICE_MID=1400
PRICE_TOP=2200
PRICE_CARE_MIN=75
PRICE_CARE_MAX=125

# ── Lead sourcing ─────────────────────────────────────────────────────────────
# Optional: Yelp Fusion API key (free tier = 500 calls/day)
# Without this, falls back to lightweight Google Maps scrape
YELP_API_KEY=

# Target cities and niches (comma-separated)
TARGET_CITIES=Kokomo,Indianapolis,Fort Wayne
TARGET_NICHES=restaurant,photography,salon,contractor,fitness,dental

# ── Lead scoring thresholds ───────────────────────────────────────────────────
SCORE_MIN_EMAIL=40       # Minimum score to attempt email outreach

# ── Sending limits (safety rails) ────────────────────────────────────────────
MAX_EMAILS_PER_DAY=25
MAX_FOLLOWUPS_PER_WEEK=50

# ── Delays between API calls (seconds) ───────────────────────────────────────
PROSPECTING_DELAY=2
OUTREACH_DELAY=5

# ── Paths ─────────────────────────────────────────────────────────────────────
DB_PATH=data/leads/leads.db
CACHE_DIR=data/cache

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Mockup hosting (Netlify free tier) ───────────────────────────────────────
# https://app.netlify.com/user/applications → Personal access tokens
NETLIFY_ACCESS_TOKEN=

# ── Domain registration (Namecheap) ──────────────────────────────────────────
# https://www.namecheap.com/support/api/intro/
# Your Namecheap account username (not email)
NAMECHEAP_USERNAME=
NAMECHEAP_API_KEY=
# Your public IP (the machine running this script) — required by Namecheap API
# Find it: curl ifconfig.me
NAMECHEAP_CLIENT_IP=
# Set to 1 to use sandbox (no real purchases) — USE THIS FOR TESTING
NAMECHEAP_SANDBOX=1

# Registrant info for domain purchases (used in Namecheap WHOIS)
REGISTRANT_FIRST_NAME=Steele
REGISTRANT_LAST_NAME=Stout
REGISTRANT_ADDRESS=123 Main St
REGISTRANT_CITY=Kokomo
REGISTRANT_STATE=IN
REGISTRANT_ZIP=46902
REGISTRANT_COUNTRY=US
REGISTRANT_PHONE=+1.5555555555
REGISTRANT_EMAIL=steele.stout@gmail.com

# ── VPS deployment (Hostinger — shared infra for curbsite.co itself) ────────
# Your Hostinger VPS IP is 187.77.5.53 (see deploy.ps1)
HOSTINGER_VPS_HOST=187.77.5.53
HOSTINGER_VPS_USER=root
# IMPORTANT: pk.ppk is PuTTY format. paramiko needs OpenSSH.
# Convert with: puttygen pk.ppk -O private-openssh -o ~/.ssh/curbsite_rsa
# Then: chmod 600 ~/.ssh/curbsite_rsa
HOSTINGER_VPS_KEY_PATH=~/.ssh/curbsite_rsa
HOSTINGER_VPS_IP=187.77.5.53
VPS_DEPLOY_ROOT=/var/www

# ── Client VPS provisioning (Hetzner — Track A, one VPS per client) ─────────
# https://console.hetzner.cloud → Security → API Tokens → Generate token
HETZNER_API_TOKEN=
# Datacenter: ash (Ashburn VA), nbg1 (Nuremberg DE), fsn1 (Falkenstein DE)
HETZNER_DATACENTER=ash
# Name of the SSH key you uploaded to Hetzner project → Security → SSH Keys
HETZNER_SSH_KEY_NAME=curbsite

# ── Reply monitoring (IMAP) ───────────────────────────────────────────────────
# For Gmail: enable IMAP in Settings → Forwarding and POP/IMAP
# Use the same credentials as SMTP_USER / SMTP_PASS
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── Owner portal ──────────────────────────────────────────────────────────────
# The URL of the CurbSite client portal (where clients upload files, pay, etc.)
CURBSITE_PORTAL_URL=https://curbsite.co/portal
# Local path where portal file uploads are synced (used by site_builder.py)
# TODO: Steele to clarify — this could be an rsync from the VPS, a Google Drive
# mount, or a direct path if the builder runs on the same VPS as the portal.
PORTAL_FILE_BASE_PATH=data/portal_uploads

# ── OpenClaw / Rook voice agent ──────────────────────────────────────────────
# Rook is NOT yet deployed. Set these once you create the OpenClaw account.
# See docs/ROOK_SETUP.md for full setup instructions.
# IMPORTANT: Rook may only make WARM calls (FCC compliance). See ROOK_SETUP.md.
OPENCLAW_API_KEY=
OPENCLAW_AGENT_ID=
OPENCLAW_API_BASE=https://api.openclaw.ai/v1

# ── Founding clients ──────────────────────────────────────────────────────────
# How many free founding-client spots are left (update as spots fill)
FOUNDING_CLIENTS_REMAINING=5

# ── Curbsite portal auth (for portal_sync.py) ─────────────────────────────────
# The email + password you use to log in at curbsite.co/crm/login
# NEVER commit these to git — they live in .env only
CURBSITE_OWNER_EMAIL=steele.stout@gmail.com
CURBSITE_OWNER_PASSWORD=
# Optional: API key for direct /api/projects access (cleaner than session cookies)
CURBSITE_CRM_API_KEY=

# ── Stripe payments ───────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook signing secret — from dashboard.stripe.com/webhooks after registering endpoint
# Register endpoint: https://curbsite.co/stripe/webhook
# Event: payment_intent.succeeded
STRIPE_WEBHOOK_SECRET=whsec_...
# Port for the webhook Flask app on the VPS (proxied by nginx)
STRIPE_WEBHOOK_PORT=5001

# ── Google PageSpeed Insights ─────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Enable: PageSpeed Insights API
GOOGLE_PAGESPEED_API_KEY=

# ── Google Reviews ────────────────────────────────────────────────────────────
# Your Curbsite Google Business "Write a Review" link
# Get it: Google Maps → search "Curbsite" → your profile → "Get more reviews"
GOOGLE_REVIEW_URL=https://g.page/r/XXXXXXXXXX/review

# ── Analytics dashboard ───────────────────────────────────────────────────────
# Public URL where the dashboard Flask app is served
# Local dev: http://localhost:5050
# Production: https://curbsite.co/analytics  (after nginx proxy setup)
DASHBOARD_URL=https://curbsite.co/analytics
DASHBOARD_PORT=5050

# ── Steele's personal notification email ─────────────────────────────────────
STEELE_EMAIL=steele.stout@gmail.com

# ── Lead scoring thresholds ───────────────────────────────────────────────────
# (also set above but repeated here for clarity)
SCORE_VOICE_THRESHOLD=70   # Flags leads for Rook voice outreach

# ── Multi-account sending (deliverability) ────────────────────────────────────
# JSON array of sending accounts. If set, overrides SMTP_HOST/SMTP_USER/SMTP_PASS.
# Each account rotates round-robin; warmup_day enforces graduated volume limits.
# Warmup schedule: day 1-7 → 5/day, day 8-14 → 15/day, day 15-21 → 30/day, day 22+ → 50/day
#
# IMPORTANT: Use a sending subdomain (e.g. mail.curbsite.co or outreach.curbsite.co).
# NEVER send cold outreach from your main domain — one spam complaint tanks your whole brand.
# See docs/EMAIL_SETUP.md for full DNS setup instructions.
#
SENDER_ACCOUNTS=[{"email":"outreach@mail.curbsite.co","smtp_host":"smtp.gmail.com","smtp_port":587,"smtp_pass":"your-app-password","from_name":"Steele @ Curbsite","warmup_day":1}]

# Warmup day for the single-account SMTP_USER fallback. Increment by 1 each day.
# Day 22+ = fully warmed (50 emails/day unlocked).
WARMUP_DAY=22

# ── CAN-SPAM compliance ────────────────────────────────────────────────────────
# Physical mailing address required in every outbound email footer (CAN-SPAM §5)
CURBSITE_ADDRESS=Curbsite.co · Kokomo, IN 46902 · United States

# Secret used to sign unsubscribe tokens — set to a long random string.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
UNSUBSCRIBE_SECRET=change-me-generate-a-real-secret

# ── Sending domain DNS (domain_reputation.py) ─────────────────────────────────
# The subdomain you send cold outreach from (NOT your main curbsite.co domain)
SENDING_DOMAIN=mail.curbsite.co
# DKIM selector as configured in Google Workspace Admin (default: "google")
DKIM_SELECTOR=google

# ═══════════════════════════════════════════════════════════════════════════════
#  TWO-SERVICE EMAIL ARCHITECTURE
# ═══════════════════════════════════════════════════════════════════════════════
#
#  ┌─ Resend (transactional) ──────────────────────────────────────────────────┐
#  │  For: build notifications, go-live emails, review requests, referral      │
#  │       drips, Steele approval alerts, Track B handoff delivery             │
#  │  These are emails clients EXPECT. No deliverability concerns.             │
#  │  Free: 3,000 emails/month. $20/mo for 50k.                               │
#  │  Sign up: https://resend.com                                              │
#  └───────────────────────────────────────────────────────────────────────────┘
#
#  ┌─ Instantly.ai (cold outreach) ─────────────────────────────────────────────┐
#  │  For: initial cold emails + follow-up sequences to prospects               │
#  │  Handles inbox warming, account rotation, deliverability, reply detection  │
#  │  ~$37/mo Hypergrowth (unlimited accounts + warming included)               │
#  │  Sign up: https://instantly.ai                                             │
#  └─────────────────────────────────────────────────────────────────────────── ┘
#
#  SendGrid / Mailgun / Amazon SES → transactional ONLY (receipts, go-live)
#  NEVER use them for cold outreach — they will ban your account.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Resend (transactional email) ──────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
# Verify your sending domain in Resend dashboard before using.
RESEND_API_KEY=re_...
# The "From" address shown in Resend emails — must be from a verified domain
# e.g. "Steele @ Curbsite <steele@curbsite.co>"
RESEND_FROM_EMAIL=Steele @ Curbsite <steele@curbsite.co>

# ── Instantly.ai (cold outreach) ──────────────────────────────────────────────
# Get your API key at: https://app.instantly.ai/app/settings/integrations
INSTANTLY_API_KEY=
# Optional: Campaign ID from Instantly dashboard.
# If set, prospects are added to this campaign (Instantly controls send schedule).
# If not set, emails are sent immediately via the direct-send API.
# Recommended: create a "Cold Outreach" campaign in Instantly and paste the ID.
INSTANTLY_CAMPAIGN_ID=
# The "From" email for direct-send mode (must be a connected inbox in Instantly)
INSTANTLY_FROM_EMAIL=outreach@mail.curbsite.co
